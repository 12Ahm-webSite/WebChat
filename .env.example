PORT=3000
MAX_PARTICIPANTS_PER_ROOM=8

# Optional TURN server for reliable WebRTC across different networks.
# Temporary TURN credentials are preferred if your TURN provider supports REST/HMAC auth.
# Example:
# TURN_URL=turn:turn.example.com:3478
# TURN_SECRET=shared-rest-api-secret
TURN_SECRET=

# Static TURN credentials fallback.
# TURN_USERNAME=localchat-user
# TURN_CREDENTIAL=localchat-password
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
